            </ul>
        </section>

        <hr>

        <section id="pedido" class="container">
            <h2> Haz tu Pedido</h2>

            <div class="pago-informacion">
                <h3>Información de Pago y Cotización:</h3>
                <blockquote class="aviso-pago">
                    <p>El pedido requiere el pago del *50% del precio total* como anticipo. El *50% restante* se liquida al recoger el producto.</p>
                    <p class="cotizacion-info">Recibirás la cotización detallada y precio final en un mensaje de WhatsApp *dentro de unos minutos*.</p>
                </blockquote>
            </div>
            
            <form id="formulario-pedido" action="procesar_pedido.php" method="POST"> 
                
                <fieldset>
                    <legend>Datos Personales</legend>
                    <label for="nombre">Nombre Completo:</label>
                    <input type="text" id="nombre" name="nombre" required>
                    
                    <label for="Telefono">Numero De Telefono :</label>
                    <input type="email" id="email" name="email" required>
                </fieldset>
                
                <fieldset>
                    <legend>Detalles del Pedido</legend>

                    <label for="tipo_pedido">Selecciona Referencia o Personalización:</label>
                    <select id="tipo_pedido" name="tipo_pedido" required>
                        <option value="">-- Elige una opción --</option>
                        <option value="Ramo Serenidad">Bouquet con tonos rosa pastel</option>
                        <option value="Arreglo 'Corazon Romantico'">Arreglo de gerberas</option>
                        <option value="Arreglo 'Mimos de Chocolate'">Ramo coquete</option>
                        <option value="Arreglo 'Capricho dulce'">Corona</option>
                        <option value="Ramo buchon">Caja sorpresa 'Propuesta'</option>
                        <option value="personalizado">Pedido Personalizado (Detallar abajo)</option>
                    </select>

                    <label for="pedido_texto">Describe tu Pedido (Flores, colores, accesorios):</label>
                    <textarea id="pedido_texto" name="pedido_texto" rows="6" required placeholder="Ej: Ramo personalizado de peonías rosas pálido y el accesorio de chocolates Suizos."></textarea>
                </fieldset>

                <fieldset>
                    <legend>Forma de Pago (Anticipo 50%)</legend>
                    <p>Elige tu método de pago inicial:</p>
                    
                    <input type="radio" id="transferencia" name="forma_pago" value="transferencia" required>
                    <label for="transferencia">Transferencia Bancaria</label>
                    <br>
                    
                    <input type="radio" id="efectivo" name="forma_pago" value="efectivo">
                    <label for="efectivo">Efectivo (Al confirmar en tienda)</label>


                    <div id="info-transferencia" style="display: none;">
                        <p> *Datos Bancarios para Transferencia*</p>
                        <p>
                            Banco: Banco Elegante<br>
                            Titular: Florería S.G..<br>
                            No. Cuenta: 9876 5432 1098 7654<br>
                            CLABE: 002123987654321099
                        </p>
                        <p class="nota-pago">⚠ Por favor, realiza la transferencia solo después de recibir la cotización por WhatsApp.</p>
                    </div>
                </fieldset>

                <button type="submit" class="btn-submit">Confirmar Pedido</button>
            </form>
        </section>

